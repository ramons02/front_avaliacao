{
  "version": 2,
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://hupstesteback-production.up.railway.app/api/v1/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://hupstesteback-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
