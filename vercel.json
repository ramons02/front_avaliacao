{
  "version": 2,
  "framework": null,
  "buildCommand": "bash vercel-build.sh",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "https://hupstesteback-production.up.railway.app/api/v1/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://hupstesteback-production.up.railway.app/api/$1"
    },
    {
      "source": "/.*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(js|wasm)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
