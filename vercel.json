{
  "cleanUrls": true,
  "framework": null,
  "installCommand": "rustup target add wasm32-unknown-unknown && cargo install --locked trunk",
  "buildCommand": "trunk build --release",
  "outputDirectory": "dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}